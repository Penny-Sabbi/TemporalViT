if CONFIG.run_data_size_study:
    data_size_rows = []
    full_train_count = len(main_split_starts["train"])

    for requested_count in CONFIG.data_size_counts:
        actual_count = full_train_count if requested_count is None else min(requested_count, full_train_count)

        for seed in CONFIG.data_size_seeds:
            loaders = build_loader_bundle(
                main_split_starts,
                MAIN_HORIZON_STEPS,
                seed,
                train_limit=actual_count,
            )

            for model_key in ("cnn_lstm_baseline", "temporal_vit_proposed"):
                spec = MODEL_SPECS[model_key]
                group_name = f"data_size_{actual_count}"
                result = train_or_load_model(spec, seed, loaders, group_name)
                row = {
                    "training_sequences": actual_count,
                    "model_key": model_key,
                    "model": spec.label,
                    "seed": seed,
                }
                row.update(result.metrics)
                data_size_rows.append(row)
                cleanup_memory()

    data_size_long = pd.DataFrame(data_size_rows)
    data_size_long.to_csv(TABLE_DIR / "data_size_results_all_seeds.csv", index=False)

    summary_rows = []
    for (count, model_key, model), group in data_size_long.groupby(
        ["training_sequences", "model_key", "model"], sort=True
    ):
        summary_rows.append(
            {
                "training_sequences": count,
                "model_key": model_key,
                "model": model,
                "mae_mean": float(group["mae"].mean()),
                "mae_std": float(group["mae"].std(ddof=1)) if len(group) > 1 else 0.0,
                "rmse_mean": float(group["rmse"].mean()),
                "rmse_std": float(group["rmse"].std(ddof=1)) if len(group) > 1 else 0.0,
            }
        )

    data_size_summary = pd.DataFrame(summary_rows)
    data_size_summary.to_csv(TABLE_DIR / "data_size_results_mean_std.csv", index=False)

    fig, axes = plt.subplots(1, 2, figsize=(14, 5))
    for model_key, label in [
        ("cnn_lstm_baseline", "CNN-LSTM baseline"),
        ("temporal_vit_proposed", "Proposed TemporalViT"),
    ]:
        frame = data_size_summary[data_size_summary["model_key"] == model_key].sort_values("training_sequences")
        axes[0].errorbar(frame["training_sequences"], frame["mae_mean"], yerr=frame["mae_std"], marker="o", label=label)
        axes[1].errorbar(frame["training_sequences"], frame["rmse_mean"], yerr=frame["rmse_std"], marker="o", label=label)

    axes[0].set_xlabel("Number of training sequences")
    axes[0].set_ylabel("MAE")
    axes[0].set_title("Data-size Study: MAE")
    axes[0].grid(True, alpha=0.3)
    axes[0].legend()

    axes[1].set_xlabel("Number of training sequences")
    axes[1].set_ylabel("RMSE")
    axes[1].set_title("Data-size Study: RMSE")
    axes[1].grid(True, alpha=0.3)
    axes[1].legend()

    save_figure(fig, "Fig14_data_size_study")

