# 18. MULTI-HORIZON STUDY
# ============================================================

multi_horizon_summary = pd.DataFrame()


def fixed_split_for_horizon(horizon_steps: int) -> Dict[str, List[int]]:
    valid_starts = build_valid_start_indices(
        cached_timestamps,
        CONFIG.sequence_length,
        horizon_steps,
        CONFIG.max_allowed_gap_minutes,
    )
    # Reuse the same chronological train/validation/test day sets.
    return split_starts_by_days(valid_starts, horizon_steps, MAIN_SPLIT_DAYS)


if CONFIG.run_multi_horizon:
    horizon_rows = []
    for horizon_minutes in CONFIG.horizon_minutes:
        horizon_steps = minutes_to_steps(horizon_minutes)
        horizon_split = fixed_split_for_horizon(horizon_steps)

        for seed in CONFIG.multi_horizon_seeds:
            loaders = build_loader_bundle(horizon_split, horizon_steps, seed)

            for model_key in ("cnn_lstm_baseline", "temporal_vit_proposed"):
                spec = MODEL_SPECS[model_key]
                group_name = f"multi_horizon_{horizon_minutes:02d}min"
                result = train_or_load_model(spec, seed, loaders, group_name)
                row = {
                    "horizon_minutes": horizon_minutes,
                    "horizon_steps": horizon_steps,
                    "model_key": model_key,
                    "model": spec.label,
                    "seed": seed,
                }
                row.update(result.metrics)
                horizon_rows.append(row)
                cleanup_memory()

    horizon_long = pd.DataFrame(horizon_rows)
    horizon_long.to_csv(TABLE_DIR / "multi_horizon_results_all_seeds.csv", index=False)

    summary_rows = []
    for (horizon, model_key, model), group in horizon_long.groupby(
        ["horizon_minutes", "model_key", "model"], sort=True
    ):
        row = {
            "horizon_minutes": horizon,
            "model_key": model_key,
            "model": model,
            "runs": len(group),
        }
        for metric in ("mae", "rmse", "r2"):
            row[f"{metric}_mean"] = float(group[metric].mean())
            row[f"{metric}_std"] = float(group[metric].std(ddof=1)) if len(group) > 1 else 0.0
        summary_rows.append(row)

    multi_horizon_summary = pd.DataFrame(summary_rows)
    multi_horizon_summary.to_csv(TABLE_DIR / "multi_horizon_results_mean_std.csv", index=False)

    fig, axes = plt.subplots(1, 2, figsize=(16, 6), sharey=False)
    for axis, model_key, title in [
        (axes[0], "cnn_lstm_baseline", "(a) CNN-LSTM baseline"),
        (axes[1], "temporal_vit_proposed", "(b) Proposed TemporalViT"),
    ]:
        frame = multi_horizon_summary[multi_horizon_summary["model_key"] == model_key].sort_values("horizon_minutes")
        x = np.arange(len(frame))
        width = 0.35
        axis.bar(x - width / 2, frame["rmse_mean"], width, yerr=frame["rmse_std"], label="RMSE")
        axis.bar(x + width / 2, frame["mae_mean"], width, yerr=frame["mae_std"], label="MAE")
        axis.set_xticks(x)
        axis.set_xticklabels([f"{value} min" for value in frame["horizon_minutes"]])
        axis.set_xlabel("Forecast horizon")
        axis.set_ylabel("Error")
        axis.set_title(title)
        axis.grid(True, axis="y", alpha=0.3)

        r2_axis = axis.twinx()
        r2_axis.plot(x, frame["r2_mean"], marker="s", linestyle="--", label="R²")
        r2_axis.set_ylabel("R²")
        r2_axis.set_ylim(0.0, 1.02)

        handles1, labels1 = axis.get_legend_handles_labels()
        handles2, labels2 = r2_axis.get_legend_handles_labels()
        axis.legend(handles1 + handles2, labels1 + labels2, loc="best")

    save_figure(fig, "Fig09_multi_horizon_performance")

